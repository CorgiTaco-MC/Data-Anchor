{
  "schemaVersion": 1,
  "id": "dataanchor",
  "version": "${version}",
  "name": "Data Anchor",
  "description": "Simple mod with helpful data attaching and networking utilities including attaching data to entities, chunks, players, and worlds with low boilerplate code. Its own system built from the ground up for multiloader support.",
  "authors": [
    "Corgi Taco"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": ""
  },
  "license": "All Rights Reserved",
  "icon": "assets/dataanchor/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.corgitaco.dataanchor.fabric.DataAnchorFabric"
    ],
    "client": [
      "dev.corgitaco.dataanchor.fabric.server.DataAnchorFabricClientModInit"
    ],
    "server": [
      "dev.corgitaco.dataanchor.fabric.client.DataAnchorFabricDedicatedServerModInit"
    ]
  },
  "mixins": [
    "dataanchor.mixins.json",
    "dataanchor-common.mixins.json"
  ],
  "depends": {
    "fabric-api": "*",
    "minecraft": ">=26.1"
  },
  "accessWidener": "dataanchor.accesswidener"
}